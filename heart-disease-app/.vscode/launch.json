{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: Run CardioSignal (app.py)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "FLASK_DEBUG": "1",
        "PORT": "5000"
      }
    },
    {
      "name": "Train: Rebuild the ensemble model (train_model.py)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/train_model.py",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
